#!/bin/zsh


set -u
set -o pipefail

## Choice of repository host "github" or "gitlab"

REPOHOST=gitlab

readonly ESC="$(tput sgr0)"
readonly BOLD="$(tput bold)"
readonly GREEN="$(tput setaf 2)"
readonly RED="$(tput setaf 1)"

SCRIPTNAME=$(readlink -f "$0")
SCRIPTDIR=$(dirname "$SCRIPTNAME")

function cleanup() {
    rm -rf ~/.deploy
    printf "${ESC}"
}

trap cleanup EXIT INT TERM QUIT


# Script to clone the mymacnix repo, stow the HOME subfolder in the repo and
# install and configure nix-darwin

function print_arrow () {
    printf "${BOLD}${GREEN}"
    eval $(echo printf '"=%.0s"' {1..$SHLVL})
    printf "> $*${ESC}\n"
}

function usage () {
    print_arrow "Usage: "
    print_arrow "  zsh -l nixsys-setup [--install=nixonly] [--branch=<feature-branch>] [--repohost=(gitlab|github)]"
    print_arrow "    The default feature-branch is 'main' if it is not specified"
    print_arrow "    The default repohost is 'gitlab' if it is not specified"
    exit 1
}

function get_gitfolder () {
    [[ ! -n "${gitfolder+1}" ]] || return
    local prompt="${BOLD}${GREEN}Enter name of subfolder within $HOME to clone mymacnix: ${ESC}"
    printf "$prompt"
    while read -r folder </dev/tty; do
        if [ "$folder" != "" ]; then
            if [[ ! -e "$HOME/$folder" ]]; then
                break
            fi
            printf "${RED}$HOME/$folder already exists - please choose another directory${ESC}\n"
        fi
        printf "$prompt"
    done
    eval "export gitfolder=$HOME/$folder"
}

# Function to check if Remote Login is active
function is_sshd_on() {
    sudo systemsetup -getremotelogin | grep -q "On"
    return $?
}

# Function to deploy secrets
function deploy_secrets() {
    mkdir ~/.deploy
    chmod 700 ~/.deploy

    ## 1. Will try automated but legacy command to enable Remote Login
    #    - but it may not work - so will fall back to manual if it fails
    print_arrow "Attempting automated legacy command to enable Remote Login"
    sudo -H /bin/launchctl load -w /System/Library/LaunchDaemons/ssh.plist
    sleep 2
    if ! is_sshd_on; then
        ## 1a. Failed automated enabling of Remote Login - fallback to manual
        print_arrow "Failed to auto-enable Remote Login via legacy launchctl command - falling back to manual"
        printf "${RED}Go to ${BOLD}System Settings> General> Sharing${ESC}\n"
        printf "${RED}Toggle ${BOLD}Remote Login${ESC}${RED} to ${BOLD}On.${ESC}\n\n"
        print_arrow "Waiting for you to enable Remote Login"
        printf "${GREEN}Will automatically continue after Remote Login is enabled${ESC}"

        # Wait the Remote Login status to be enabled
        while ! is_sshd_on; do
            printf "${GREEN}.${ESC}"
            sleep 2
        done
    fi

    print_arrow "Remote Login is ENABLED\n"

    USER_NAME=$(/usr/bin/id -un)
    IP_ADDR=$(/usr/bin/osascript -e "IPv4 address of (system info)")

    ## Need to wait for deploy.map and token to appear first
    SSH_STATE=0 # 0=no connection, 1=waiting for auth, 2=connected
    printf "${GREEN}Waiting for deploy.map and token in ~/.deploy folder...${ESC}\n"
    if [ ! -f ~/.deploy/deploy.map ] || [ ! -f ~/.deploy/token ]; then
        printf "${RED}At the remote host, do the following:${ESC}\n"
        printf "${RED}${BOLD}1. Make a copy of the installScript/deploy-sample.map and edit it to select the appropriate secrets to deploy from 1Password${ESC}\n"
        printf "${RED}${BOLD}2. Execute the installScripts/scpdeploy.sh script and enter ${USER_NAME}@${IP_ADDR} as the Remote Host, select the 1Password Vaults that need to be read and the deploy.map file to copy${ESC}\n"

        while [ ! -f ~/.deploy/deploy.map ] || [ ! -f ~/.deploy/token ] || [ ! -s ~/.deploy/token ]; do
          printf "${GREEN}.${ESC}"
          while IFS= read -r line; do
              if [ $SSH_STATE -eq 0 ]; then
                  if [[ "$line" =~ ^"sshd-auth: $USER" ]]; then
                      # Received an SSH connection - waiting for password
                      SSH_STATE=1
                      printf "\n${GREEN}${BOLD}Received SSH connection - waiting to authenticate${ESC}\n"
                      break
                  fi
              elif [ $SSH_STATE -eq 1 ]; then
                  if [[ "$line" =~ ^"sshd-session: "$USER(@notty)?[[:space:]]*$ ]]; then
                      # Received an SSH authentication
                      SSH_STATE=2
                      printf "\n${GREEN}${BOLD}Received SSH authentication${ESC}\n"
                      break
                  fi
              fi
          done < <(ps -ax -o args= | grep "^sshd")
          sleep 2
        done
        sleep 1
        printf "\n"
    fi

    printf "${GREEN}${BOLD}Received deploy.map and token in ~/.deploy folder${ESC}\n"

    ## Initialize OP_SERVICE_ACCOUNT_TOKEN
    OP_SERVICE_ACCOUNT_TOKEN="$(cat ~/.deploy/token)" 
    export OP_SERVICE_ACCOUNT_TOKEN

    grep -vE '^\s*(#|$)' ~/.deploy/deploy.map | while IFS="|" read -r target secret mode; do

      # Trim leading/trailing whitespace WITHOUT using xargs
      # This syntax is pure bash and safe for spaces inside the path
      target="${target#"${target%%[![:space:]]*}"}"
      target="${target%"${target##*[![:space:]]}"}"

      secret="${secret#"${secret%%[![:space:]]*}"}"
      secret="${secret%"${secret##*[![:space:]]}"}"

      mode="${mode#"${mode%%[![:space:]]*}"}"
      mode="${mode%"${mode##*[![:space:]]}"}"
      #
      # 2. MANUALLY EXPAND TILDE (~)
      # If target starts with ~/, replace it with the $HOME path
      if [[ "$target" == "~/"* ]]; then
        target="${HOME}${target#\~}"
      fi

      echo "Deploying to: '$target' with mode $mode"

      # Ensure parent directory exists
      mkdir -p "$(dirname "$target")"

      # Use quotes around variables to handle spaces in the CLI call
      op read "$secret" --out-file "$target" --force --file-mode $mode

    done

    # Clear the OP_SERVICE_ACCOUNT_TOKEN
    unset OP_SERVICE_ACCOUNT_TOKEN
    # Remove the ~/.deploy directory
    rm -rf ~/.deploy
}

## Test to confirm nix has been installed
if [[ ! $(/sbin/mount | grep -w "/nix") ]]; then
    printf "${BOLD}${RED}Error: Nix has not yet been installed - nixsys-setup script cannot be executed${ESC}\n"
    exit 1
fi

OPTINSTALL="all"
BRANCH="main"
CMDARGS=( "$@" )
while test $# -gt 0; do
    case "$1" in
        --install=nixonly)
            OPTINSTALL="${1##--install=}";;
        --branch=*)
            BRANCH="${1##--branch=}";;
        --repohost=*)
            REPOHOST="${1##--repohost=}";;
        *)
            echo "Invalid option $1"
            usage;;
    esac
    shift
done

## Executed the startup scripts to check what whether nix or nix-darwin installed
DARWININSTALLED=1
ZSCRIPTSRUN=0

if [[ ! $(nix --version 2>/dev/null) ]]; then
    ## Executed the startup scripts to ensure nix path is present
    [[ -f /etc/zshenv ]] && . /etc/zshenv
    [[ -f /etc/zprofile ]] && . /etc/zprofile
    [[ -f /etc/zshrc ]] && . /etc/zshrc
    ZSCRIPTSRUN=1
    if [[ ! $(nix --version 2>/dev/null) ]]; then
        printf "${BOLD}${RED}nix cannot be executed even after executing /etc/z* startup scripts - something is wrong with this setup${ESC}\n"
        exit 1
    fi
fi

if [[ ! $(darwin-version --version 2>/dev/null) ]]; then
    if [[ ZSCRIPTSRUN -eq 1 ]]; then
        DARWININSTALLED=0
    else
        [[ -f /etc/zshenv ]] && . /etc/zshenv
        [[ -f /etc/zprofile ]] && . /etc/zprofile
        [[ -f /etc/zshrc ]] && . /etc/zshrc
        if [[ ! $(darwin-version --version 2>/dev/null) ]]; then
            DARWININSTALLED=0
        fi
    fi
fi

# Define where the config is
NIX_DARWIN_DIR="/etc/nix-darwin"
SCRIPT_PATH="$NIX_DARWIN_DIR/generate_machine_info.sh"
MINFO_FILE="$NIX_DARWIN_DIR/machine-info.nix"

if [ ! -f $SCRIPT_PATH ]; then
    # 1. Ensure the directory exists
    sudo mkdir -p "$NIX_DARWIN_DIR"

    # 2. Write the script to the disk
    sudo -H tee "$SCRIPT_PATH" >/dev/null <<'EOF'
#!/usr/bin/env bash
IS_VM=$(/usr/sbin/sysctl -n kern.hv_vmm_present)
XHOSTNAME=$(/usr/sbin/scutil --get LocalHostName)
BGROUPID=$(dscl . -read /Groups/nixbld PrimaryGroupID 2>/dev/null | awk '{ print $2 }')
if [ -z "$BGROUPID" ]; then
  BGROUPID=350
fi
MINFO_FILE="$1"
cat <<EOF2 > "$MINFO_FILE"
{
  is_vm = $IS_VM;
  hostname = "${XHOSTNAME}";
  buildGroupID = $BGROUPID;
}
EOF2
EOF

    # 3. Make the script executable
    sudo -H chmod +x "$SCRIPT_PATH"

    # 4. Run the script *now* to create the initial machine-info.nix file
    sudo -H "$SCRIPT_PATH" "$MINFO_FILE"
fi

if [[ $DARWININSTALLED -eq 1 ]]; then
    printf "${BOLD}${RED}nix-darwin already installed - re-running darwin-rebuild switch${ESC}\n"
    sudo -H darwin-rebuild switch
    exit
fi

# Added code to install Xcode command line tools
print_arrow "Checking whether Xcode command line tools have been installed"
sudo -H xcode-select -p &> /dev/null
if [ $? -ne 0 ]; then
  print_arrow "Command Line Tools for Xcode not found. Installing from softwareupdate…"
# This temporary file prompts the 'softwareupdate' utility to list the Command Line Tools
  touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress;
  PROD=$(softwareupdate -l | grep "\*.*Command Line" | tail -n 1 | sed 's/^[^C]* //')
  softwareupdate -i "$PROD" --verbose;
else
  print_arrow "Command Line Tools for Xcode have been installed."
fi

git -C "$SCRIPTDIR" rev-parse 2>/dev/null
if [ $? -ne 0 ]; then
    ## Script folder is not a git folder
    get_gitfolder

    mkdir -p ~/.config/git

    print_arrow "Cloning branch ${BRANCH} of mymacnix repo"
    export BRANCH
    export REPOHOST
    export GREEN
    export RED
    export BOLD
    export ESC
    export FN_print_arrow=$(whence -f print_arrow)
    export FN_is_sshd_on=$(whence -f is_sshd_on)
    export FN_deploy_secrets=$(whence -f deploy_secrets)
    [ -f /etc/zshenv ] && . /etc/zshenv
    [ -f /etc/zprofile ] && . /etc/zprofile
    [ -f /etc/zshrc ] && . /etc/zshrc
    NIXPKGS_ALLOW_UNFREE=1 nix-shell -p git stow openssh age _1password-cli --command '
    eval "$FN_print_arrow"
    eval "$FN_is_sshd_on"
    eval "$FN_deploy_secrets"

    echo "Populating ~/.ssh/known_hosts with public keys of github.com and gitlab.com"
    # Save current umask to set temporary umask
    save_umask=$(umask)
    umask 077

    # Populate known_hosts with public keys of github.com and gitlab.com
    mkdir -p ~/.ssh
    ssh-keyscan github.com >> ~/.ssh/known_hosts
    ssh-keyscan gitlab.com >> ~/.ssh/known_hosts

    # Deploy secrets
    deploy_secrets

    # Generate age public keys if missing
    if [ -f ~/.age/key.txt ] && [ ! -f ~/.age/public.txt ]; then
        age-keygen -y -o ~/.age/public.txt ~/.age/key.txt
        chmod 644 ~/.age/public.txt
    fi
    if [ -f ~/.age/nixid_key.txt ] && [ ! -f ~/.age/nixid_public.txt ]; then
        age-keygen -y -o ~/.age/nixid_public.txt ~/.age/nixid_key.txt
        chmod 644 ~/.age/nixid_public.txt
    fi

    # Restore original umask
    umask "$save_umask"

    echo "Cloning branch ${BRANCH} from ${REPOHOST}"
    git clone --branch ${BRANCH} --recurse-submodules https://${REPOHOST}.com/khsoh/mymacnix.git "$gitfolder"
    mkdir -p ~/Library/LaunchAgents
    cd $gitfolder
    ./git-remote-init.sh
    source "$gitfolder/dostow.sh"
    cd ..

    killall ssh-agent
    eval $(ssh-agent -s) > /dev/null
    ssh-add ~/.ssh/nixid_ed25519

    git clone git@${REPOHOST}.com:khsoh/caskmasapps.git

    cd caskmasapps
    ./dostow.sh
    '

    print_arrow "Completed cloning the repository"
else
    gitfolder=$SCRIPTDIR
fi

NEWCMDARGS=${CMDARGS[@]//--install=*/}
if [[ $OPTINSTALL == "nixonly" ]]; then
    print_arrow "Completed installing only nix and cloning repo"
    print_arrow "To proceed, open a new terminal and execute:"
    print_arrow "   cd \"$gitfolder\""
    print_arrow "   zsh -l nixsys-setup $NEWCMDARGS"
    exit
fi

cd "$gitfolder"

## Generate the primary user nix file
./genusernix.sh

## Update the nix channels
sudo -H nix-channel --update

## Move /etc/zshrc and /etc/bashrc files
if [ -f /etc/zshrc ]; then
    sudo -H mv /etc/zshrc /etc/zshrc.before-nix-darwin
fi
if [ -f /etc/bashrc ]; then
    sudo -H mv /etc/bashrc /etc/bashrc.before-nix-darwin
fi
print_arrow "Installing nix-darwin"
zsh -l scripts/darwin-autoinstall



#!/bin/sh


set -u
set -o pipefail

REPOHOST=gitlab

readonly ESC="$(tput sgr0)"
readonly BOLD="$(tput bold)"
readonly GREEN="$(tput setaf 2)"
readonly RED="$(tput setaf 1)"

# Script to perform automated installation of Nix on MacOS and clone mymacnix to install nix-Darwin
#

{ # Prevent execution if this script was only partially downloaded

function print_arrow () {
    printf "${BOLD}${GREEN}"
    eval $(echo printf '"=%.0s"' {1..$SHLVL})
    printf "> $*${ESC}\n"
}

function makerepo () {
    if [[ "$1" == "github" ]]; then
        echo "https://raw.githubusercontent.com/khsoh/mymacnix/$2/$3"
    elif [[ "$1" == "gitlab" ]]; then
        echo "https://gitlab.com/khsoh/mymacnix/-/raw/$2/$3"
    else
        echo "Improper host $1 specified.  Repo host must be github or gitlab"
        exit 1
    fi
}

function usage () {
    print_arrow "Usage: "
    print_arrow "  sh <(curl -L $(makerepo ${REPOHOST} "main" "nix-autoinstall")) [--install=nixonly] [--branch=<feature-branch>] [--repohost=(gitlab|github)]"
    print_arrow "    The default feature-branch is 'main' if it is not specified"
    print_arrow "    The default repohost is 'gitlab' if it is not specified"
    exit 1
}

# Function to check if Remote Login is active
function is_sshd_on() {
    sudo systemsetup -getremotelogin | grep -q "On"
    return $?
}

# Prompt user copy nixid_ed25519 and nixid_ed25519.pub to ~/.ssh
# And age keys to ~/.age
function copy_secretkeys() {
    mkdir -p ~/.ssh
    mkdir -p ~/.age
    NIX_PRIVKEY="$HOME/.ssh/nixid_ed25519"
    NIX_PUBKEY="$HOME/.ssh/nixid_ed25519.pub"
    NIX_AGEPRIVKEY="$HOME/.age/nixid_key.txt"
    NIX_AGEPUBKEY="$HOME/.age/nixid_public.txt"
    AGEPRIVKEY="$HOME/.age/key.txt"
    AGEPUBKEY="$HOME/.age/public.txt"

    ## 1. Prompt user to enable Remote Login
    print_arrow "COPYING NIXID SSH KEYS"
    print_arrow "Checking Remote Login status"
    is_sshd_on
    if [ "$?" != "0" ]; then
        print_arrow "Remote Login is disabled - please enable Remote Login:"
        printf "${RED}Go to ${BOLD}System Settings> General> Sharing${ESC}\n"
        printf "${RED}Toggle ${BOLD}Remote Login${ESC}${RED} to ${BOLD}On.${ESC}\n\n"
        print_arrow "Waiting for you to enable Remote Login"
        printf "${GREEN}Will automatically continue after Remote Login is enabled${ESC}"

        # Wait the Remote Login status to be enabled
        while ! is_sshd_on; do
            printf "${GREEN}.${ESC}"
            sleep 2
        done
    fi

    print_arrow "Remote Login is ENABLED\n"

    USER_NAME=$(id -un)
    IP_ADDR=$(osascript -e "IPv4 address of (system info)")

    ## 2. Copy the SSH keys
    if [ ! -f "$NIX_PRIVKEY" ]; then
        print_arrow "Copy the NIXID SSH private key from the other machine:\n"
        printf "${RED}${BOLD}./dosshcopy${ESC}\n"
        printf "${GREEN}OR${ESC}\n"
        printf "${RED}${BOLD}ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null ${USER_NAME}@${IP_ADDR} \"cat > ~/.ssh/nixid_ed25519\" < <(op read \"op://<vault>/<item>/private key?ssh-format=openssh)\"${ESC}\n\n"
        print_arrow "Waiting for NIXID SSH Private key to appear in ~/.ssh folder"
        print_arrow "Will automatically continue after NIXID SSH Private key is copied to the folder"

        while [ ! -f "$NIX_PRIVKEY" ]; do
            printf "${GREEN}.${ESC}"
            sleep 2
        done

        echo ""
        chmod 600 "$NIX_PRIVKEY"
        print_arrow "NIXID SSH Private Key copied"
    else
        print_arrow "NIXID SSH Private Key already present"
    fi

    if [ ! -f "$NIX_PUBKEY" ]; then
        print_arrow "Missing NIXID SSH Public Key - autogenerating NIXID SSH Public Key..."
        ssh-keygen -y -f "$NIX_PRIVKEY" > "$NIX_PUBKEY"
        chmod 644 "$NIX_PUBKEY"
    fi
    print_arrow "Completed getting SSH Keys\n"

    ### Copy the age keys
    if [ ! -f "$AGEPRIVKEY" ] && [ ! -f "$NIX_AGEPRIVKEY" ]; then
        print_arrow "Copy the AGE private key from the other machine:\n"
        printf "${RED}${BOLD}./doagecopy${ESC}\n"
        printf "${GREEN}OR${ESC}\n"
        printf "${RED}${BOLD}ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null ${USER_NAME}@${IP_ADDR} \"cat > ~/.age/[nixid_]key.txt\" < <(op read \"op://<vault>/<item>/notesPlain\")${ESC}\n"

        print_arrow "Waiting for AGE Private key to appear in ~/.age folder"
        print_arrow "Will automatically continue after AGE Private key is copied to the folder"

        # Wait for either the NIXID or personal AGE private key to appear
        while [ ! -f "$AGEPRIVKEY" ] && [ ! -f "$NIX_AGEPRIVKEY" ]; do
            printf "${GREEN}.${ESC}"
            sleep 2
        done

        echo ""
        if [ -f "$NIX_AGEPRIVKEY" ]; then
            chmod 600 "$NIX_AGEPRIVKEY"
        else
            chmod 600 "$AGEPRIVKEY"
        fi
        print_arrow "AGE Private Key copied"
    else
        print_arrow "AGE Private Key already present"
    fi

    if [ ! -f "$AGEPUBKEY" ]; then
        print_arrow "Missing AGE Public Key - will be autogenerated later"
    fi
    print_arrow "Completed getting AGE Private Key\n"
}

oops() {
    echo "$0:" "$@" >&2
    exit 1
}

umask 0022

# Perform automated install
nixtmpDir="$(mktemp -d -t nixautoinstalldir.XXXXXXXXX || \
          oops "Can't create temporary directory for downloading the nix install scripts")"

cleanup() {
    rm -rf "$nixtmpDir"
}
trap cleanup EXIT INT QUIT TERM

function get_gitfolder () {
    [[ ! -n "${gitfolder+1}" ]] || return
    local prompt="${BOLD}${GREEN}Enter name of subfolder within $HOME to clone mymacnix: ${ESC}"
    printf "$prompt"
    while read -r folder </dev/tty; do
        if [ "$folder" != "" ]; then
            if [[ ! -e "$HOME/$folder" ]]; then
                break
            fi
            printf "${RED}$HOME/$folder already exists - please choose another directory${ESC}\n"
        fi
        printf "$prompt"
    done
    eval "export gitfolder=$HOME/$folder"
}

OPTINSTALL="all"
BRANCH="main"
CMDARGS=( "$@" )
while test $# -gt 0; do
    case "$1" in
        --install=nixonly)
            OPTINSTALL="${1##--install=}";;
        --branch=*)
            BRANCH="${1##--branch=}";;
        --repohost=*)
            REPOHOST="${1##--repohost=}";;
        *)
            echo "Invalid option $1"
            usage;;
    esac
    shift
done


# Test if Nix is already installed
if [[ $(nix --version 2>/dev/null) ]]; then
    printf "${BOLD}${RED}Nix already installed - nix-autoinstall will not be executed${ESC}\n"
    exit 1
fi

# Prompt user for git folder early in install process because the Nix installation
# time takes a while - so we want the automated installation can proceed without 
# interruption after all the user inputs are collected first.
get_gitfolder

print_arrow "Starting to auto-install nix from https://nixos.org/nix/install"

yes | sh <<EOF
$(curl -L https://nixos.org/nix/install)
EOF

# Copy SSH and AGE kesy
copy_secretkeys 

print_arrow "Downloading and executing nixsys-setup from ${BRANCH} branch of mymacnix repo"
curl -L $(makerepo ${REPOHOST} "${BRANCH}" "nixsys-setup") -o ${nixtmpDir}/nixsys-setup
zsh -l ${nixtmpDir}/nixsys-setup ${CMDARGS[@]:-}

} # End of wrapping


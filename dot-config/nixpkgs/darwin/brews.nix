{
  config,
  pkgs,
  lib,
  ...
}:
let
  cfghost = config.secrets.target.host;
in
{
  ### Homebrew setup.
  homebrew = {
    enable = true;

    # Use Brewfile in /nix/store that is generated by configuration.nix when invoking brew bundle command
    global = {
      brewfile = true;
      autoUpdate = false;
    };

    # Upgrade casks in homebrew.casks
    greedyCasks = true;

    ### Setup for updates via Nix
    onActivation = {
      upgrade = true;
      autoUpdate = true;
      ## The following allows Nix to uninstall stuff absent from cask list
      cleanup = "zap";
    };
    ### End Setup for updates via Nix

    brews = cfghost.hostbrew.brews;

    casks = cfghost.hostbrew.casks;

    masApps = cfghost.hostbrew.masApps;
  };
}

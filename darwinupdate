#!/usr/bin/env zsh



set -u
set -o pipefail

readonly ESC="$(tput sgr0)"
readonly BOLD="$(tput bold)"
readonly GREEN="$(tput setaf 2)"
readonly RED="$(tput setaf 1)"

function cleanup() {
    printf "${ESC}"
}

trap cleanup EXIT INT TERM QUIT

if [ ! -e /etc/nix-channels/system-channels ]; then
    sudo mkdir -p /etc/nix-channels
    sudo chmod a+rx /etc/nix-channels
    sudo cp /var/root/.nix-channels /etc/nix-channels/system-channels
    sudo chmod a+r /etc/nix-channels/system-channels
fi

SCRIPTNAME=$(readlink -f "$0")
SCRIPTDIR=$(dirname "$SCRIPTNAME")

printf "${BOLD}${GREEN}Updating nix-darwin...${ESC}\n"
UPDCHAN=$(cat /etc/nix-channels/system-channels)
if [ -n "$UPDCHAN" ]; then
    printf "${BOLD}${GREEN}====== Starting to update root channels ======\n$(awk '{ print "--- ", $2, $1 }' /etc/nix-channels/system-channels)${ESC}\n"
    printf "${BOLD}${RED}"
    sudo -H nix-channel --update --verbose 2>&1 | tail -n +2
    printf "${ESC}"
    printf "${BOLD}${GREEN}====== Completed updating root channels ======${ESC}\n\n\n"
    sleep 3
fi

UPDCHAN=$(nix-channel --list)
if [ -n "$UPDCHAN" ]; then
    printf "${BOLD}${GREEN}====== Starting to update user channels ======\n$(awk '{ print "--- ", $1, $2 }' <(echo $UPDCHAN))${ESC}\n"
    printf "${BOLD}${RED}"
    nix-channel --update --verbose 2>&1 | tail -n +2
    printf "${ESC}"
    printf "${BOLD}${GREEN}====== Completed updating user channels ======${ESC}\n\n\n"
    sleep 3
fi

WORKFILE=~/.working-nixpkgs
NONWORKFILE=~/.nonworking-nixpkgs
[ -f $WORKFILE ] || touch $WORKFILE
[ -f $NONWORKFILE ] || touch $NONWORKFILE
LAST_GOOD_REV=$(awk 'END {print $1}' $WORKFILE || echo 0)
LATEST_NIXPKGS_REV=$(curl -Ls -o /dev/null -w %{url_effective} $(grep "nixpkgs$" /etc/nix-channels/system-channels | awk '{print $1}') | sed -e 's/.*\.//')
BUILDARGS=""
BUILDREV="$LATEST_NIXPKGS_REV"
if grep -q "^$LATEST_NIXPKGS_REV" $NONWORKFILE; then
    if [ "$LAST_GOOD_REV" = "0" ]; then
        OPTIONS="[l/x]"
    else
        OPTIONS="[l/g/x]"
    fi
    echo "nixpkgs rev $LATEST_NIXPKGS_REV failed to build previously"
    echo "What would you like to build? $OPTIONS"
    echo " l/L - Latest nixpkgs rev"
    if [ "$LAST_GOOD_REV" != "0" ]; then
        echo " g/G - Last good rev"
    fi
    echo " x/X - Exit"
    echo -n "$OPTIONS "
    read -k 1 i
    case "$i" in
        l|L)
            ;;
        g|G)
            if [ "$LAST_GOOD_REV" = "0" ]; then
                exit 0
            fi
            BUILDARGS="-I nixpkgs=https://github.com/NixOS/nixpkgs/archive/${LAST_GOOD_REV}.tar.gz"
            BUILDREV="$LAST_GOOD_REV"
            ;;
        *)
            exit 0
            ;;
    esac
fi

printf "${BOLD}${GREEN}====== Starting to rebuild system ========${ESC}\n"

## Generate the primary user nix file
$SCRIPTDIR/genusernix.sh

sudo -H darwin-rebuild switch --verbose $(echo $BUILDARGS)
BUILDRESULT=$?

# Create a secure temporary file
TMPFILE=$(mktemp) || exit 1

# Ensure temporary file is cleaned up if script exits early
trap 'rm -f "$TMPFILE"' EXIT

if [ "$BUILDRESULT" = "0" ]; then
    if grep -q "^$BUILDREV" $WORKFILE ; then
        sed -i "/^$BUILDREV.*$/c$BUILDREV : $(date +"%d %b %Y %I:%M:%S %p")" $WORKFILE
    else
        echo "$BUILDREV : $(date +"%d %b %Y %I:%M:%S %p")" >> $WORKFILE
    fi
    if [ "$(wc -l < $WORKFILE | xargs)" -gt 40 ]; then
        if tail -n 20 $WORKFILE > "$TMPFILE"; then
            mv "$TMPFILE" "$WORKFILE"
        fi
    fi
    sed -i "/^$BUILDREV/d" $NONWORKFILE
else
    if grep -q "^$BUILDREV" $NONWORKFILE ; then
        sed -i "/^$BUILDREV.*$/c$BUILDREV : $(date +"%d %b %Y %I:%M:%S %p")" $NONWORKFILE
    else
        echo "$BUILDREV : $(date +"%d %b %Y %I:%M:%S %p")" >> $NONWORKFILE
    fi
    if [ "$(wc -l < $NONWORKFILE | xargs)" -gt 40 ]; then
        if tail -n 20 $NONWORKFILE > "$TMPFILE"; then
            mv "$TMPFILE" "$NONWORKFILE"
        fi
    fi
fi

printf "\n${BOLD}${GREEN}====== Checking permissions of terminal programs ======${ESC}\n"
$SCRIPTDIR/dot-config/nixpkgs/launchdagents/checktermperms.sh

printf "${BOLD}${GREEN}Completed rebuilding system${ESC}\n"

